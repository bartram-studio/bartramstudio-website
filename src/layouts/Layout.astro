---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Handcrafted resin shell art, coastal decor, and custom pieces by Amanda in St. Johns, Florida.',
  image = '/images/og-default.jpg',
} = Astro.props;

const fullTitle = title === 'Bartram Studio' ? title : `${title} — Bartram Studio`;
const currentPath = Astro.url.pathname;

// ── Typography theme ────────────────────────────────────────────────────────
const brandEntries = await getCollection('brand');
const brandSettings = brandEntries.find(e => e.id === 'settings.md')?.data;
const typographyTheme = brandSettings?.typographyTheme ?? 'coastal-serif';

// Each theme defines:
//   fontsUrl   — Google Fonts @import URL (the part inside url('...'))
//   fontDisplay — value for --font-display CSS custom property
//   fontBody    — value for --font-body CSS custom property
//
// coastal-serif: values are IDENTICAL to global.css defaults, so the page
// looks exactly the same as before this feature existed.
const THEMES: Record<string, { fontsUrl: string; fontDisplay: string; fontBody: string }> = {
  'coastal-serif': {
    fontsUrl:    'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap',
    fontDisplay: "'Cormorant Garamond', Georgia, serif",
    fontBody:    "'Jost', 'Gill Sans', sans-serif",
  },
  'clean-modern': {
    fontsUrl:    'https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap',
    fontDisplay: "'DM Serif Display', Georgia, serif",
    fontBody:    "'DM Sans', system-ui, sans-serif",
  },
  'soft-handmade': {
    fontsUrl:    'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Lato:wght@300;400;700&display=swap',
    fontDisplay: "'Playfair Display', Georgia, serif",
    fontBody:    "'Lato', 'Helvetica Neue', sans-serif",
  },
};

const theme = THEMES[typographyTheme] ?? THEMES['coastal-serif'];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <title>{fullTitle}</title>
  {/* Open Graph */}
  <meta property="og:site_name" content="Bartram Studio" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content="https://bartramstudio.com/images/brand/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Bartram Studio — Handcrafted coastal art from St. Johns, Florida" />
  {/* Twitter / X Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://bartramstudio.com/images/brand/og-image.jpg" />
  {/* Typography theme — overrides --font-display and --font-body set in global.css */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href={theme.fontsUrl} />
  <style define:vars={{ fontDisplay: theme.fontDisplay, fontBody: theme.fontBody }}>
    :root {
      --font-display: var(--fontDisplay);
      --font-body:    var(--fontBody);
    }
  </style>
</head>
<body>

  <!-- ── Navigation ── -->
  <header class="site-header" id="site-header">
    <div class="container header-inner">

      <a href="/" class="logo" aria-label="Bartram Studio home">
        <img
          src="/images/brand/logo-primary.svg"
          alt="Bartram Studio"
          class="logo-svg"
          width="260"
          height="48"
        />
      </a>

      <nav class="site-nav" aria-label="Main navigation">
        <ul>
          <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a></li>
          <li><a href="/products" class:list={[{ active: currentPath.startsWith('/products') }]}>Shop</a></li>
          <li><a href="/about" class:list={[{ active: currentPath === '/about' }]}>About</a></li>
          <li><a href="/contact" class:list={[{ active: currentPath === '/contact' }]}>Contact</a></li>
        </ul>
      </nav>

      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

    </div>
  </header>

  <!-- ── Mobile Nav ── -->
  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/products">Shop</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <!-- ── Footer ── -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <img
          src="/images/brand/logo-primary.svg"
          alt="Bartram Studio"
          class="footer-logo-svg"
          width="208"
          height="39"
        />
        <p>Handcrafted coastal art from<br>St. Johns, Florida.</p>
      </div>
      <div class="footer-links">
        <h4>Navigate</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/products">Shop</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-links">
        <h4>Connect</h4>
        <ul>
          <li><a href="mailto:hello@bartramstudio.com">hello@bartramstudio.com</a></li>
          <li><a href="https://instagram.com/bartramstudio" target="_blank" rel="noopener">Instagram</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Bartram Studio &mdash; All rights reserved.</p>
        <p class="footer-tagline">Each piece made with love in Northeast Florida.</p>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
/* ── Header ── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(250, 247, 242, 0.95);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--sand-dark);
  transition: box-shadow 0.3s;
}

.site-header.scrolled {
  box-shadow: 0 2px 20px rgba(0,0,0,0.07);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
  gap: 2rem;
}

.logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
}

.logo-svg {
  display: block;
  height: 48px;
  width: auto;
  /* Prevent SVG from inheriting unexpected colours */
}

.footer-logo-svg {
  display: block;
  height: 39px;
  width: auto;
  opacity: 0.85;
}

.site-nav ul {
  display: flex;
  list-style: none;
  gap: 2.5rem;
}

.site-nav a {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--driftwood);
  transition: color 0.2s;
  position: relative;
  padding-bottom: 2px;
}

.site-nav a::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 1.5px;
  background: var(--tide-dark);
  transition: width 0.25s var(--ease);
}

.site-nav a:hover,
.site-nav a.active {
  color: var(--tide-dark);
}

.site-nav a:hover::after,
.site-nav a.active::after {
  width: 100%;
}

/* ── Mobile Toggle ── */
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}

.nav-toggle span {
  display: block;
  width: 24px;
  height: 1.5px;
  background: var(--driftwood-dk);
  transition: all 0.25s;
}

/* ── Mobile Nav ── */
.mobile-nav {
  display: none;
  position: fixed;
  top: 72px;
  left: 0;
  right: 0;
  background: var(--shell);
  border-bottom: 1px solid var(--sand-dark);
  z-index: 99;
  transform: translateY(-10px);
  opacity: 0;
  pointer-events: none;
  transition: all 0.25s var(--ease);
}

.mobile-nav.open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.mobile-nav ul {
  list-style: none;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.mobile-nav a {
  display: block;
  padding: 0.85rem 0;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--driftwood);
  border-bottom: 1px solid var(--sand-dark);
  transition: color 0.2s;
}

.mobile-nav a:hover { color: var(--tide-dark); }

/* ── Footer ── */
.site-footer {
  background: var(--sand);
  border-top: 1px solid var(--sand-dark);
  margin-top: auto;
}

.footer-inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 3rem;
  padding-block: 3rem 2.5rem;
}

.footer-brand p {
  margin-top: 0.75rem;
  font-size: 0.875rem;
  line-height: 1.6;
}

.footer-links h4 {
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--tide-dark);
  margin-bottom: 1rem;
}

.footer-links ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.footer-links a {
  font-size: 0.875rem;
  color: var(--driftwood);
  transition: color 0.2s;
}

.footer-links a:hover { color: var(--tide-dark); }

.footer-bottom {
  border-top: 1px solid var(--sand-dark);
  padding-block: 1.25rem;
}

.footer-bottom .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.footer-bottom p {
  font-size: 0.78rem;
  color: var(--driftwood);
  max-width: none;
}

.footer-tagline {
  font-family: var(--font-display);
  font-style: italic;
}

@media (max-width: 768px) {
  .site-nav { display: none; }
  .nav-toggle { display: flex; }
  .mobile-nav { display: block; }

  .footer-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .footer-bottom .container {
    flex-direction: column;
    text-align: center;
  }
}
</style>

<script>
// Sticky header shadow
const header = document.getElementById('site-header');
window.addEventListener('scroll', () => {
  header?.classList.toggle('scrolled', window.scrollY > 10);
});

// Mobile nav toggle
const toggle = document.getElementById('nav-toggle');
const mobileNav = document.getElementById('mobile-nav');

toggle?.addEventListener('click', () => {
  const isOpen = mobileNav?.classList.toggle('open');
  toggle.setAttribute('aria-expanded', String(isOpen));
  mobileNav?.setAttribute('aria-hidden', String(!isOpen));
});
</script>
