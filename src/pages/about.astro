---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const siteEntries = await getCollection('site');
const a = siteEntries.find(e => e.id === 'about.md')!.data;
const heroBgClass = a.heroBg ? `bg-${a.heroBg}` : '';

// introParagraphs is the canonical field name
const paragraphs = a.introParagraphs ?? [];
const steps = a.processSteps ?? [];
const values = a.valuesParagraphs ?? [];
---

<Layout
  title="About"
  description="Learn about Amanda and the story behind Bartram Studio — handcrafted coastal art from St. Johns, Florida."
>

  <section class={`page-hero ${heroBgClass}`}>
    <div class="container">
      <p class="page-hero__eyebrow">{a.pageEyebrow}</p>
      <h1>{a.pageTitle}</h1>
      <p>{a.pageIntro}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container about-intro">
      <div class="about-intro__image">
        <div class="about-frame">
          <div class="about-img-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>A photo of Amanda</span>
          </div>
        </div>
        <div class="about-frame-accent"></div>
      </div>

      <div class="about-intro__text">
        <p class="section-eyebrow">{a.introEyebrow}</p>
        <h2>{a.introTitle}</h2>
        {paragraphs.map(para => <p>{para}</p>)}
      </div>
    </div>
  </section>

  <!-- What I make -->
  <section class="section craft-section">
    <div class="container">
      <div class="section-head" style="text-align:center; max-width: 560px; margin-inline: auto; margin-bottom: 3rem;">
        <p class="section-eyebrow">{a.craftEyebrow}</p>
        <h2>{a.craftTitle}</h2>
        <p>{a.craftText}</p>
      </div>

      <div class="process-grid">
        {steps.map((step, i) => (
          <div class="process-step">
            <div class="process-step__number">{String(i + 1).padStart(2, '0')}</div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section values-section">
    <div class="container values-inner">
      <div class="values-text">
        <p class="section-eyebrow">{a.valuesEyebrow}</p>
        <h2>{a.valuesTitle}</h2>
        {values.map(para => <p>{para}</p>)}
        <a href="/products" class="btn btn--outline" style="margin-top: 1.5rem;">Browse the Shop</a>
      </div>
      <div class="values-quote">
        <blockquote>
          <p>"{a.quoteText}"</p>
          <cite>{a.quoteCitation}</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section--sm contact-strip">
    <div class="container">
      <div class="contact-strip__inner">
        <div>
          <h3>{a.contactCtaTitle}</h3>
          <p>{a.contactCtaText}</p>
        </div>
        <a href="/contact" class="btn btn--coral">{a.contactCtaButtonText}</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.section-eyebrow {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--tide);
  margin-bottom: 0.6rem;
  max-width: none;
}

/* ── Intro ── */
.about-intro {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 5rem;
  align-items: start;
}

.about-intro__image {
  position: relative;
  padding-bottom: 1.5rem;
  padding-right: 1.5rem;
}

.about-frame {
  position: relative;
  z-index: 1;
  width: 100%;
  aspect-ratio: 3/4;
  background: var(--sand);
  overflow: hidden;
}

.about-frame-accent {
  position: absolute;
  bottom: 0;
  right: 0;
  width: calc(100% - 20px);
  height: calc(100% - 20px);
  border: 2px solid var(--sand-dark);
  z-index: 0;
}

.about-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  color: var(--driftwood);
  opacity: 0.4;
}

.about-img-placeholder svg {
  width: 56px;
  height: 56px;
}

.about-img-placeholder span {
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.about-intro__text {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.about-intro__text h2 {
  color: var(--driftwood-dk);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  margin-top: 0.5rem;
  margin-bottom: 0.5rem;
}

/* ── Process ── */
.craft-section {
  background: var(--sand);
}

.process-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 2.5rem;
}

.process-step {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.process-step__number {
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 300;
  color: var(--tide-light);
  line-height: 1;
  letter-spacing: -0.02em;
}

.process-step h3 {
  font-size: 1.3rem;
  color: var(--driftwood-dk);
}

.process-step p {
  font-size: 0.9rem;
  line-height: 1.7;
}

/* ── Values ── */
.values-inner {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 5rem;
  align-items: center;
}

.values-text {
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}

.values-text h2 {
  color: var(--driftwood-dk);
  font-size: clamp(1.5rem, 2.5vw, 2.2rem);
  margin-top: 0.5rem;
}

.values-quote {
  position: relative;
}

.values-quote blockquote {
  border-left: 3px solid var(--tide-light);
  padding-left: 1.75rem;
}

.values-quote blockquote p {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  color: var(--driftwood-dk);
  line-height: 1.6;
  max-width: 40ch;
}

.values-quote cite {
  display: block;
  margin-top: 1rem;
  font-size: 0.8rem;
  font-style: normal;
  color: var(--driftwood);
  letter-spacing: 0.05em;
}

/* ── Contact Strip ── */
.contact-strip {
  background: var(--tide-dark);
  color: var(--white);
  padding-block: 3rem;
}

.contact-strip__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}

.contact-strip h3 {
  font-size: 1.5rem;
  color: var(--white);
  margin-bottom: 0.5rem;
}

.contact-strip p {
  color: var(--tide-light);
  max-width: 55ch;
}

.contact-strip .btn--coral {
  flex-shrink: 0;
  background: var(--white);
  color: var(--tide-dark);
}

.contact-strip .btn--coral:hover {
  background: var(--sand);
}

@media (max-width: 768px) {
  .about-intro,
  .values-inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .about-intro__image { display: none; }
  .contact-strip__inner { flex-direction: column; align-items: flex-start; }
}
</style>
