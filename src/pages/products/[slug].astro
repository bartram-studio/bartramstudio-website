---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;

// Related products (same category, not self)
const allProducts = await getCollection('products');
const related = allProducts
  .filter(p => p.slug !== product.slug && p.data.category === data.category)
  .slice(0, 3);

const isAvailable = data.status === 'available';
const subject = encodeURIComponent(`I'm interested in: ${data.title}`);
const body = encodeURIComponent(`Hi Amanda,\n\nI saw "${data.title}" on your website and I'm interested in purchasing it.\n\nPlease let me know if it's still available and how to proceed.\n\nThank you!`);
---

<Layout
  title={data.title}
  description={data.description.slice(0, 155)}
  image={data.images?.[0]}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/products">Shop</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{data.title}</span>
    </div>
  </nav>

  <!-- Product Detail -->
  <section class="section">
    <div class="container product-layout">

      <!-- Gallery -->
      <div class="gallery">
        <div class="gallery__main" id="gallery-main">
          {data.images && data.images.length > 0 ? (
            <img
              src={data.images[0]}
              alt={data.title}
              id="main-img"
              onerror="this.parentElement.innerHTML='<div class=\'gallery-placeholder\'><svg viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'currentColor\' stroke-width=\'1\'><rect x=\'3\' y=\'3\' width=\'18\' height=\'18\' rx=\'2\'/><circle cx=\'8.5\' cy=\'8.5\' r=\'1.5\'/><polyline points=\'21 15 16 10 5 21\'/></svg><p>Photo coming soon</p></div>'"
            />
          ) : (
            <div class="gallery-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              <p>Photos coming soon</p>
            </div>
          )}
        </div>

        {data.images && data.images.length > 1 && (
          <div class="gallery__thumbs">
            {data.images.map((img, i) => (
              <button
                class={`gallery__thumb ${i === 0 ? 'gallery__thumb--active' : ''}`}
                data-src={img}
                aria-label={`View image ${i + 1}`}
              >
                <img src={img} alt={`${data.title} view ${i + 1}`} />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="product-info">
        <p class="product-info__category">{data.category}</p>
        <h1 class="product-info__title">{data.title}</h1>

        <div class="product-info__meta">
          <span class="product-info__price">${data.price}</span>
          <span class={`badge badge--${data.status}`}>
            {data.status === 'available' ? 'Available' : data.status === 'pending' ? 'Pending Sale' : 'Sold'}
          </span>
          {data.quantity > 1 && data.status === 'available' && (
            <span class="product-info__qty">{data.quantity} available</span>
          )}
        </div>

        <div class="divider"><span>✦</span></div>

        <div class="product-info__desc">
          <p>{data.description}</p>
        </div>

        {data.customOrderAvailable && (
          <div class="custom-note">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Custom orders available for this style — <a href="/contact">reach out to inquire</a>.</span>
          </div>
        )}

        <div class="product-actions">
          {isAvailable ? (
            <>
              <a
                href={`/contact?subject=${subject}&body=${body}`}
                class="btn btn--primary btn--lg"
              >
                I'm Interested
              </a>
              <p class="product-actions__note">
                Clicking "I'm Interested" will open a contact form pre-filled with this item's details.
              </p>
            </>
          ) : (
            <>
              <button class="btn btn--ghost btn--lg" disabled>
                {data.status === 'pending' ? 'Pending Sale' : 'Sold'}
              </button>
              {data.customOrderAvailable && (
                <a href="/contact" class="btn btn--outline">Request Similar Piece</a>
              )}
              <p class="product-actions__note">
                {data.status === 'pending' ? 'This piece has a pending sale. Contact us to be waitlisted.' : 'This piece has sold. We may be able to create something similar.'}
              </p>
            </>
          )}
        </div>

        <div class="product-details">
          <h4>Details</h4>
          <dl>
            <div>
              <dt>Category</dt>
              <dd>{data.category}</dd>
            </div>
            <div>
              <dt>Availability</dt>
              <dd style="text-transform: capitalize;">{data.status}</dd>
            </div>
            {data.quantity > 0 && (
              <div>
                <dt>Quantity</dt>
                <dd>{data.quantity}</dd>
              </div>
            )}
            <div>
              <dt>Custom Orders</dt>
              <dd>{data.customOrderAvailable ? 'Yes' : 'No'}</dd>
            </div>
          </dl>
        </div>

      </div>
    </div>
  </section>

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="section--sm related-section">
      <div class="container">
        <div class="divider"><span>More {data.category}</span></div>
        <div class="grid-3" style="margin-top: 2rem;">
          {related.map(p => (
            <a href={`/products/${p.slug}`} class="product-card" style="text-decoration:none;">
              <div class="product-card__img-wrap">
                {p.data.images && p.data.images.length > 0 ? (
                  <img src={p.data.images[0]} alt={p.data.title} loading="lazy" />
                ) : (
                  <div class="img-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
                )}
                <span class={`badge badge--${p.data.status} product-card__badge`}>
                  {p.data.status === 'available' ? 'Available' : p.data.status === 'pending' ? 'Pending' : 'Sold'}
                </span>
              </div>
              <div class="product-card__body">
                <p class="product-card__category">{p.data.category}</p>
                <h3 class="product-card__title">{p.data.title}</h3>
                <p class="product-card__price">${p.data.price}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Layout>

<style>
.breadcrumb {
  padding-block: 1rem;
  background: var(--sand);
  border-bottom: 1px solid var(--sand-dark);
}

.breadcrumb .container {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: var(--driftwood);
}

.breadcrumb a {
  color: var(--driftwood);
  transition: color 0.2s;
}

.breadcrumb a:hover { color: var(--tide-dark); }

.breadcrumb span[aria-current] {
  color: var(--tide-dark);
}

/* ── Layout ── */
.product-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

/* ── Gallery ── */
.gallery__main {
  aspect-ratio: 1;
  overflow: hidden;
  background: var(--sand);
  border-radius: var(--radius);
}

.gallery__main img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s var(--ease);
}

.gallery-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  color: var(--driftwood);
  opacity: 0.4;
}

.gallery-placeholder svg {
  width: 60px;
  height: 60px;
}

.gallery-placeholder p {
  font-size: 0.85rem;
  letter-spacing: 0.08em;
}

.gallery__thumbs {
  display: flex;
  gap: 0.75rem;
  margin-top: 0.75rem;
}

.gallery__thumb {
  width: 72px;
  height: 72px;
  overflow: hidden;
  border: 2px solid transparent;
  border-radius: var(--radius);
  cursor: pointer;
  padding: 0;
  background: none;
  transition: border-color 0.2s;
}

.gallery__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.gallery__thumb--active {
  border-color: var(--tide-dark);
}

/* ── Info ── */
.product-info__category {
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--tide);
  font-weight: 500;
  margin-bottom: 0.5rem;
  max-width: none;
}

.product-info__title {
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  color: var(--driftwood-dk);
  margin-bottom: 1rem;
}

.product-info__meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.product-info__price {
  font-size: 1.75rem;
  font-family: var(--font-display);
  color: var(--coral);
  font-weight: 400;
}

.product-info__qty {
  font-size: 0.75rem;
  color: var(--driftwood);
  letter-spacing: 0.08em;
}

.product-info__desc p {
  line-height: 1.8;
  max-width: 55ch;
}

.custom-note {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  padding: 0.875rem 1rem;
  background: var(--sand);
  border-left: 3px solid var(--tide);
  margin-top: 1rem;
  font-size: 0.85rem;
  color: var(--driftwood);
}

.custom-note svg { flex-shrink: 0; margin-top: 2px; color: var(--tide-dark); }
.custom-note a { color: var(--tide-dark); text-decoration: underline; }

.product-actions {
  margin-top: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.btn--lg {
  padding: 1rem 2.5rem;
  font-size: 0.85rem;
  justify-content: center;
}

.product-actions__note {
  font-size: 0.78rem;
  color: var(--driftwood);
  max-width: 48ch;
  line-height: 1.5;
}

.product-details {
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--sand-dark);
}

.product-details h4 {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--tide);
  margin-bottom: 1rem;
}

.product-details dl {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.product-details dl > div {
  display: flex;
  gap: 1rem;
}

.product-details dt {
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--driftwood);
  min-width: 130px;
}

.product-details dd {
  font-size: 0.85rem;
  color: var(--ink);
}

.related-section {
  background: var(--sand);
  padding-block: 3rem;
}

@media (max-width: 900px) {
  .product-layout {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
}
</style>

<script>
// Gallery thumbnail switcher
const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery__thumb');
const mainImg = document.getElementById('main-img') as HTMLImageElement;

thumbs.forEach(thumb => {
  thumb.addEventListener('click', () => {
    thumbs.forEach(t => t.classList.remove('gallery__thumb--active'));
    thumb.classList.add('gallery__thumb--active');
    if (mainImg && thumb.dataset.src) {
      mainImg.src = thumb.dataset.src;
    }
  });
});
</script>
