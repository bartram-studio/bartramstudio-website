---
// Canonical Decap CMS admin entry point.
// Cloudflare Pages has been verified to serve /admin from this Astro page.
// public/admin/config.yml remains the Decap CMS configuration file.
// Do not create public/admin/index.html; it causes ambiguity with this route.
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bartram Studio — Content Manager</title>
</head>
<body>
  <!-- Decap CMS mounts here automatically -->
  <script src="https://unpkg.com/decap-cms@3/dist/decap-cms.js"></script>

  <!-- Inline preview — Attempt #5 -->
  <!-- Targets: Site Content > About Page -->
  <!-- Renders: hero (with live heroBg colour), intro, craft section, contact CTA -->
  <!-- Safe: try/catch preserved; diagnostic logging preserved; guards preserved -->
  <script>
    (function () {
      // ── Diagnostic logging ────────────────────────────────────────────────
      console.log('[preview-poc] typeof window.CMS:', typeof window.CMS);
      console.log('[preview-poc] typeof window.createClass:', typeof window.createClass);
      console.log('[preview-poc] typeof window.h:', typeof window.h);

      // ── Guards ────────────────────────────────────────────────────────────
      if (typeof window.CMS === 'undefined') {
        console.error('[preview-poc] window.CMS is undefined. Aborting.');
        return;
      }
      if (typeof window.createClass === 'undefined') {
        console.error('[preview-poc] window.createClass is undefined. Aborting.');
        return;
      }
      if (typeof window.h === 'undefined') {
        console.error('[preview-poc] window.h is undefined. Aborting.');
        return;
      }

      // ── Inline style tokens (mirrors global.css Palette C) ────────────────
      var c = {
        shell:       '#F7F4EF',
        sand:        '#EDE8E0',
        sandDark:    '#D9C3A3',
        ink:         '#3C3F41',
        driftwood:   '#B7B1A6',
        driftwoodDk: '#3C3F41',
        tide:        '#AFC8C0',
        tideDark:    '#4A7A70',
        coral:       '#E8D7D0',
        white:       '#ffffff',
      };

      var fonts = {
        display: "'Cormorant Garamond', Georgia, serif",
        body:    "'Jost', 'Gill Sans', sans-serif",
      };

      // ── Hero background colour map (mirrors config.yml heroBg options) ────
      // Keys are the exact CMS option values from public/admin/config.yml.
      // Fallback is --sand (#EDE8E0), matching the live page-hero default.
      var heroBgMap = {
        '':            '#EDE8E0', // "Site Default (Sand)" — empty value → --sand fallback
        'soft-shell':  '#F7F4EF',
        'sea-glass':   '#AFC8C0',
        'resin-amber': '#D9C3A3',
        'shell-pink':  '#E8D7D0',
        'driftwood':   '#B7B1A6',
      };
      var heroBgFallback = '#EDE8E0'; // --sand (also used for any unrecognised value)

      // ── Helper: safe ImmutableJS list → JS array ──────────────────────────
      function toArr(val) {
        if (!val) return [];
        if (typeof val.toArray === 'function') return val.toArray();
        if (Array.isArray(val)) return val;
        return [];
      }

      // ── Helper: safe ImmutableJS map field get ────────────────────────────
      function getField(item, key) {
        if (!item) return '';
        if (typeof item.get === 'function') return item.get(key) || '';
        return item[key] || '';
      }

      // ── Preview component ─────────────────────────────────────────────────
      try {
        var AboutPreview = window.createClass({
          render: function () {
            var entry  = this.props.entry;
            var get    = function (key) { return entry.getIn(['data', key]) || ''; };

            var intraParagraphs = toArr(entry.getIn(['data', 'introParagraphs']));
            var processSteps    = toArr(entry.getIn(['data', 'processSteps']));

            var h = window.h;

            // ── Shared style objects ────────────────────────────────────────
            var wrap = {
              fontFamily: fonts.body,
              background: c.shell,
              color:      c.ink,
              minHeight:  '100vh',
              lineHeight: '1.7',
              fontSize:   '16px',
            };

            var eyebrowStyle = {
              fontFamily:    fonts.body,
              fontSize:      '0.68rem',
              letterSpacing: '0.2em',
              textTransform: 'uppercase',
              color:         c.tideDark,
              marginBottom:  '0.6rem',
            };

            var h1Style = {
              fontFamily:   fonts.display,
              fontWeight:   '400',
              fontSize:     'clamp(2rem, 5vw, 3.5rem)',
              color:        c.driftwoodDk,
              lineHeight:   '1.15',
              marginBottom: '0.5rem',
            };

            var h2Style = {
              fontFamily:   fonts.display,
              fontWeight:   '400',
              fontSize:     'clamp(1.4rem, 3vw, 2.2rem)',
              color:        c.driftwoodDk,
              lineHeight:   '1.15',
              marginBottom: '0.75rem',
              marginTop:    '0.25rem',
            };

            var pStyle = {
              fontSize:    '0.95rem',
              color:       c.driftwoodDk,
              maxWidth:    '62ch',
              marginBottom:'0.6rem',
            };

            var sectionStyle = {
              padding:   '3rem 2rem',
              maxWidth:  '900px',
              margin:    '0 auto',
            };

            // ── Hero ────────────────────────────────────────────────────────
            // heroBg: read CMS field, map to hex, fall back to --sand default
            var heroBgValue = entry.getIn(['data', 'heroBg']) || '';
            var heroBgColor = heroBgMap[heroBgValue] || heroBgFallback;

            var hero = h('section', {
              style: {
                background:  heroBgColor,
                padding:     '3.5rem 2rem',
                textAlign:   'center',
              }
            },
              h('p',  { style: eyebrowStyle }, get('pageEyebrow')),
              h('h1', { style: Object.assign({}, h1Style, { marginBottom: '0.75rem' }) }, get('pageTitle')),
              h('p',  { style: {
                fontFamily: fonts.display,
                fontStyle:  'italic',
                fontSize:   '1.1rem',
                color:      c.driftwood,
              }}, get('pageIntro'))
            );

            // ── Intro section ───────────────────────────────────────────────
            var introParaNodes = intraParagraphs.map(function (para, i) {
              var text = typeof para === 'string' ? para : getField(para, 'paragraph');
              return h('p', { style: pStyle, key: i }, text);
            });

            var intro = h('section', { style: sectionStyle },
              h('p',  { style: eyebrowStyle }, get('introEyebrow')),
              h('h2', { style: h2Style },      get('introTitle')),
              introParaNodes.length > 0
                ? introParaNodes
                : h('p', { style: Object.assign({}, pStyle, { color: c.driftwood, fontStyle: 'italic' }) }, '(No intro paragraphs yet)')
            );

            // ── Craft / Process steps ───────────────────────────────────────
            var stepNodes = processSteps.map(function (step, i) {
              var title = getField(step, 'title');
              var body  = getField(step, 'body');
              return h('div', {
                key: i,
                style: {
                  borderLeft:  '3px solid ' + c.tide,
                  paddingLeft: '1rem',
                  marginBottom:'1.25rem',
                }
              },
                h('p', { style: {
                  fontFamily:    fonts.display,
                  fontSize:      '1.8rem',
                  fontWeight:    '300',
                  color:         c.tide,
                  lineHeight:    '1',
                  marginBottom:  '0.2rem',
                }}, String(i + 1).padStart(2, '0')),
                h('h3', { style: {
                  fontFamily:   fonts.display,
                  fontSize:     '1.2rem',
                  fontWeight:   '400',
                  color:        c.driftwoodDk,
                  marginBottom: '0.3rem',
                }}, title),
                h('p', { style: pStyle }, body)
              );
            });

            var craft = h('section', {
              style: Object.assign({}, sectionStyle, { background: c.sand, maxWidth: '100%', padding: '3rem 2rem' })
            },
              h('div', { style: { maxWidth: '900px', margin: '0 auto' } },
                h('p',  { style: eyebrowStyle }, get('craftEyebrow')),
                h('h2', { style: h2Style },      get('craftTitle')),
                h('p',  { style: Object.assign({}, pStyle, { marginBottom: '2rem' }) }, get('craftText')),
                stepNodes.length > 0
                  ? h('div', { style: {
                      display:             'grid',
                      gridTemplateColumns: 'repeat(auto-fill, minmax(200px, 1fr))',
                      gap:                 '1.5rem',
                    }}, stepNodes)
                  : h('p', { style: Object.assign({}, pStyle, { color: c.driftwood, fontStyle: 'italic' }) }, '(No process steps yet)')
              )
            );

            // ── Contact CTA strip ───────────────────────────────────────────
            var cta = h('section', {
              style: {
                background: c.tideDark,
                padding:    '2.5rem 2rem',
                display:    'flex',
                alignItems: 'center',
                justifyContent: 'space-between',
                gap:        '1.5rem',
                flexWrap:   'wrap',
              }
            },
              h('div', {},
                h('h3', { style: {
                  fontFamily:   fonts.display,
                  fontSize:     '1.4rem',
                  fontWeight:   '400',
                  color:        c.white,
                  marginBottom: '0.4rem',
                }}, get('contactCtaTitle')),
                h('p', { style: Object.assign({}, pStyle, { color: c.tide, maxWidth: '50ch' }) },
                  get('contactCtaText'))
              ),
              h('span', { style: {
                display:       'inline-block',
                padding:       '0.75rem 2rem',
                background:    c.white,
                color:         c.tideDark,
                fontFamily:    fonts.body,
                fontSize:      '0.78rem',
                fontWeight:    '500',
                letterSpacing: '0.12em',
                textTransform: 'uppercase',
              }}, get('contactCtaButtonText') || 'Get in Touch')
            );

            // ── Assemble ────────────────────────────────────────────────────
            return h('div', { style: wrap }, hero, intro, craft, cta);
          }
        });

        window.CMS.registerPreviewTemplate('about', AboutPreview);
        console.log('[preview-poc] registerPreviewTemplate("about") succeeded.');

      } catch (err) {
        console.error('[preview-poc] registerPreviewTemplate("about") failed:', err);
      }

      // ── Contact Page preview ────────────────────────────────────────────
      // Fields: pageEyebrow, pageTitle, pageIntro (hero)
      //         formTitle, formIntro (form column)
      //         email, instagramHandle, location (sidebar contact methods)
      //         customOrdersTitle, customOrdersParagraphs, responseTime (sidebar card)
      //         faqItems (sidebar FAQ card)
      //         heroBg (hero background colour)
      try {
        var ContactPreview = window.createClass({
          render: function () {
            var entry = this.props.entry;
            var get   = function (key) { return entry.getIn(['data', key]) || ''; };
            var h     = window.h;

            // Reuse shared style tokens from outer scope (c, fonts, heroBgMap, heroBgFallback)

            // ── Hero ──────────────────────────────────────────────────────
            var heroBgValue = entry.getIn(['data', 'heroBg']) || '';
            var heroBgColor = heroBgMap[heroBgValue] || heroBgFallback;

            var eyebrowStyle = {
              fontFamily:    fonts.body,
              fontSize:      '0.68rem',
              letterSpacing: '0.2em',
              textTransform: 'uppercase',
              color:         c.tideDark,
              marginBottom:  '0.6rem',
            };

            var h1Style = {
              fontFamily:   fonts.display,
              fontWeight:   '400',
              fontSize:     'clamp(2rem, 5vw, 3.5rem)',
              color:        c.driftwoodDk,
              lineHeight:   '1.15',
              marginBottom: '0.5rem',
            };

            var h2Style = {
              fontFamily:   fonts.display,
              fontWeight:   '400',
              fontSize:     'clamp(1.3rem, 2.5vw, 2rem)',
              color:        c.driftwoodDk,
              lineHeight:   '1.15',
              marginBottom: '0.6rem',
              marginTop:    '0',
            };

            var pStyle = {
              fontSize:     '0.95rem',
              color:        c.driftwoodDk,
              maxWidth:     '62ch',
              marginBottom: '0.6rem',
            };

            var labelStyle = {
              fontFamily:    fonts.body,
              fontSize:      '0.65rem',
              fontWeight:    '500',
              letterSpacing: '0.1em',
              textTransform: 'uppercase',
              color:         c.tide,
              marginBottom:  '0.15rem',
            };

            var hero = h('section', {
              style: {
                background: heroBgColor,
                padding:    '3.5rem 2rem',
                textAlign:  'center',
              }
            },
              h('p',  { style: eyebrowStyle }, get('pageEyebrow')),
              h('h1', { style: Object.assign({}, h1Style, { marginBottom: '0.75rem' }) }, get('pageTitle')),
              h('p',  { style: {
                fontFamily: fonts.display,
                fontStyle:  'italic',
                fontSize:   '1.1rem',
                color:      c.driftwood,
              }}, get('pageIntro'))
            );

            // ── Two-column layout ─────────────────────────────────────────
            // Left: form guidance  |  Right: sidebar cards

            // Form column
            var formCol = h('div', { style: { flex: '1.3', minWidth: '0' } },
              h('h2', { style: h2Style }, get('formTitle')),
              h('p',  { style: Object.assign({}, pStyle, { marginBottom: '1.5rem' }) }, get('formIntro')),
              // Placeholder form fields
              h('div', { style: { display: 'flex', flexDirection: 'column', gap: '0.75rem' } },
                ['Your Name', 'Email Address', 'Subject'].map(function (lbl, i) {
                  return h('div', { key: i, style: { display: 'flex', flexDirection: 'column', gap: '0.25rem' } },
                    h('span', { style: labelStyle }, lbl),
                    h('div',  { style: {
                      height:     '2.4rem',
                      background: c.white,
                      border:     '1.5px solid ' + c.sandDark,
                      borderRadius: '2px',
                    }})
                  );
                }),
                h('div', { style: { display: 'flex', flexDirection: 'column', gap: '0.25rem' } },
                  h('span', { style: labelStyle }, 'Message'),
                  h('div',  { style: {
                    height:       '7rem',
                    background:   c.white,
                    border:       '1.5px solid ' + c.sandDark,
                    borderRadius: '2px',
                  }})
                ),
                h('div', { style: {
                  display:       'inline-block',
                  padding:       '0.75rem 2rem',
                  background:    c.tideDark,
                  color:         c.white,
                  fontFamily:    fonts.body,
                  fontSize:      '0.78rem',
                  fontWeight:    '500',
                  letterSpacing: '0.12em',
                  textTransform: 'uppercase',
                  marginTop:     '0.5rem',
                }}, 'Send Message')
              )
            );

            // Sidebar — contact methods card
            var customParas = toArr(entry.getIn(['data', 'customOrdersParagraphs']));
            var faqItems    = toArr(entry.getIn(['data', 'faqItems']));

            var cardStyle = {
              background:   c.white,
              border:       '1.5px solid ' + c.sandDark,
              borderRadius: '2px',
              padding:      '1.25rem',
              marginBottom: '1rem',
            };

            var contactMethodRow = function (iconPath, labelText, valueText) {
              return h('div', { style: { display: 'flex', gap: '0.75rem', alignItems: 'flex-start', marginBottom: '0.75rem' } },
                h('div', { style: {
                  width:          '28px',
                  height:         '28px',
                  background:     c.sand,
                  borderRadius:   '50%',
                  flexShrink:     '0',
                  display:        'flex',
                  alignItems:     'center',
                  justifyContent: 'center',
                }},
                  h('svg', { width: '14', height: '14', viewBox: '0 0 24 24', fill: 'none', stroke: c.tideDark, strokeWidth: '1.5' },
                    h('path', { d: iconPath })
                  )
                ),
                h('div', {},
                  h('p', { style: labelStyle }, labelText),
                  h('span', { style: { fontSize: '0.875rem', color: c.driftwoodDk } }, valueText)
                )
              );
            };

            var contactCard = h('div', { style: cardStyle },
              h('h3', { style: Object.assign({}, h2Style, { fontSize: '1.05rem', marginBottom: '1rem' }) }, 'Other ways to reach me'),
              contactMethodRow(
                'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22,6 12,13 2,6',
                'Email',
                get('email')
              ),
              contactMethodRow(
                'M4 4m16 0a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H4a5 5 0 0 1-5-5V9a5 5 0 0 1 5-5h16z M8.5 8.5m3.5 3.5a4 4 0 1 0 4 4',
                'Instagram',
                get('instagramHandle')
              ),
              contactMethodRow(
                'M12 2a7 7 0 0 1 7 7c0 5.25-7 13-7 13S5 14.25 5 9a7 7 0 0 1 7-7z M12 9m0 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2',
                'Location',
                get('location')
              )
            );

            // Sidebar — custom orders card
            var customCard = h('div', { style: Object.assign({}, cardStyle, { background: c.sand, borderColor: c.tide }) },
              h('h3', { style: Object.assign({}, h2Style, { fontSize: '1.05rem', marginBottom: '0.75rem' }) },
                get('customOrdersTitle')),
              customParas.map(function (p, i) {
                var text = typeof p === 'string' ? p : getField(p, 'paragraph');
                return h('p', { key: i, style: pStyle }, text);
              }),
              get('responseTime') && h('p', { style: { fontSize: '0.82rem', color: c.driftwood, marginTop: '0.5rem' } },
                'Response time: ',
                h('strong', {}, get('responseTime'))
              )
            );

            // Sidebar — FAQ card
            var faqCard = faqItems.length > 0
              ? h('div', { style: cardStyle },
                  h('h3', { style: Object.assign({}, h2Style, { fontSize: '1.05rem', marginBottom: '0.75rem' }) }, 'Frequently Asked'),
                  faqItems.map(function (item, i) {
                    var q = getField(item, 'question');
                    var a = getField(item, 'answer');
                    return h('div', { key: i, style: { borderBottom: '1px solid ' + c.sandDark, paddingBlock: '0.6rem' } },
                      h('p', { style: { fontSize: '0.875rem', fontWeight: '500', color: c.driftwoodDk, marginBottom: '0.25rem' } }, q),
                      h('p', { style: { fontSize: '0.85rem', color: c.driftwood } }, a)
                    );
                  })
                )
              : null;

            var sidebar = h('div', { style: { flex: '1', minWidth: '0' } },
              contactCard, customCard, faqCard
            );

            var mainContent = h('section', { style: { padding: '3rem 2rem', maxWidth: '1100px', margin: '0 auto' } },
              h('div', { style: { display: 'flex', gap: '3rem', alignItems: 'flex-start', flexWrap: 'wrap' } },
                formCol, sidebar
              )
            );

            return h('div', { style: {
              fontFamily: fonts.body,
              background: c.shell,
              color:      c.ink,
              minHeight:  '100vh',
              lineHeight: '1.7',
              fontSize:   '16px',
            }}, hero, mainContent);
          }
        });

        window.CMS.registerPreviewTemplate('contact', ContactPreview);
        console.log('[preview-poc] registerPreviewTemplate("contact") succeeded.');

      } catch (err) {
        console.error('[preview-poc] registerPreviewTemplate("contact") failed:', err);
      }

      // ── Homepage preview — Phase 1 ──────────────────────────────────────
      // Sections: Hero, About Strip, Custom Order CTA
      // Fields:   heroEyebrow, heroTitle, heroTitleEmphasis, heroLead, heroBg,
      //           aboutEyebrow, aboutTitle, aboutText,
      //           ctaTitle, ctaTitleEmphasis, ctaText, ctaButtonText, ctaBg
      // Skipped:  Featured Products (requires live product data — Phase 2)
      //           Categories (dynamic product-derived list — Phase 2)
      try {
        var HomePreview = window.createClass({
          render: function () {
            var entry = this.props.entry;
            var get   = function (key) { return entry.getIn(['data', key]) || ''; };
            var h     = window.h;

            // Reuse shared tokens: c, fonts, heroBgMap, heroBgFallback

            // ── Shared styles (local to this render) ─────────────────────
            var wrap = {
              fontFamily: fonts.body,
              background: c.shell,
              color:      c.ink,
              minHeight:  '100vh',
              lineHeight: '1.7',
              fontSize:   '16px',
            };

            var eyebrowStyle = {
              fontFamily:    fonts.body,
              fontSize:      '0.68rem',
              letterSpacing: '0.2em',
              textTransform: 'uppercase',
              color:         c.tideDark,
              marginBottom:  '0.5rem',
            };

            var pStyle = {
              fontSize:     '0.95rem',
              color:        c.driftwoodDk,
              maxWidth:     '62ch',
              marginBottom: '0.6rem',
            };

            // ── Hero ──────────────────────────────────────────────────────
            // heroTitleEmphasis: rendered as italic teal second line inside h1,
            // matching the live site's emphasis treatment.
            var heroBgValue = entry.getIn(['data', 'heroBg']) || '';
            var heroBgColor = heroBgMap[heroBgValue] || heroBgFallback;

            var titleEmphasis = get('heroTitleEmphasis');
            var h1Content = titleEmphasis
              ? [
                  get('heroTitle'),
                  h('span', { key: 'em', style: {
                    display:    'block',
                    fontStyle:  'italic',
                    color:      c.tideDark,
                  }}, titleEmphasis),
                ]
              : get('heroTitle');

            var hero = h('section', {
              style: {
                background: heroBgColor,
                padding:    '4rem 2rem',
                textAlign:  'center',
              }
            },
              h('p', { style: eyebrowStyle }, get('heroEyebrow')),
              h('h1', { style: {
                fontFamily:   fonts.display,
                fontWeight:   '400',
                fontSize:     'clamp(2.2rem, 5vw, 4rem)',
                color:        c.driftwoodDk,
                lineHeight:   '1.15',
                marginBottom: '1rem',
              }}, h1Content),
              h('p', { style: {
                fontFamily:   fonts.display,
                fontStyle:    'italic',
                fontSize:     'clamp(1rem, 1.8vw, 1.2rem)',
                color:        c.driftwood,
                marginInline: 'auto',
                maxWidth:     '60ch',
              }}, get('heroLead'))
            );

            // ── Skipped sections notice ───────────────────────────────────
            // Featured Products and Categories sections are not rendered in
            // Phase 1 because they require live product collection data.
            var skippedNotice = h('section', {
              style: {
                background:  c.sand,
                padding:     '1.5rem 2rem',
                textAlign:   'center',
                borderTop:   '1px dashed ' + c.sandDark,
                borderBottom:'1px dashed ' + c.sandDark,
              }
            },
              h('p', { style: {
                fontSize:   '0.75rem',
                fontFamily: fonts.body,
                color:      c.driftwood,
                fontStyle:  'italic',
              }}, 'Featured Products and Categories sections are not shown in this preview.')
            );

            // ── About Strip ───────────────────────────────────────────────
            // Dark teal background, two-column: text left, image placeholder right.
            var aboutStrip = h('section', {
              style: {
                background: c.tideDark,
                padding:    '3.5rem 2rem',
              }
            },
              h('div', { style: {
                maxWidth:   '1100px',
                margin:     '0 auto',
                display:    'flex',
                gap:        '3rem',
                alignItems: 'center',
                flexWrap:   'wrap',
              }},
                // Text column
                h('div', { style: { flex: '1', minWidth: '260px' } },
                  h('p', { style: Object.assign({}, eyebrowStyle, { color: c.tide, opacity: '0.85' }) },
                    get('aboutEyebrow')),
                  h('h2', { style: {
                    fontFamily:   fonts.display,
                    fontWeight:   '400',
                    fontSize:     'clamp(1.5rem, 3vw, 2.4rem)',
                    color:        c.white,
                    lineHeight:   '1.15',
                    marginBottom: '1rem',
                    marginTop:    '0.25rem',
                  }}, get('aboutTitle')),
                  h('p', { style: Object.assign({}, pStyle, { color: c.tide, maxWidth: '52ch' }) },
                    get('aboutText')),
                  h('span', { style: {
                    display:       'inline-block',
                    marginTop:     '1.25rem',
                    padding:       '0.7rem 1.75rem',
                    border:        '1.5px solid ' + c.tide,
                    color:         c.white,
                    fontFamily:    fonts.body,
                    fontSize:      '0.78rem',
                    fontWeight:    '500',
                    letterSpacing: '0.12em',
                    textTransform: 'uppercase',
                  }}, 'Learn More')
                ),
                // Image placeholder column
                h('div', { style: {
                  flex:           '1',
                  minWidth:       '220px',
                  aspectRatio:    '4/3',
                  background:     'rgba(255,255,255,0.08)',
                  display:        'flex',
                  alignItems:     'center',
                  justifyContent: 'center',
                  color:          'rgba(255,255,255,0.25)',
                  fontSize:       '0.75rem',
                  letterSpacing:  '0.1em',
                  textTransform:  'uppercase',
                }}, 'Studio photo')
              )
            );

            // ── Custom Order CTA ──────────────────────────────────────────
            // ctaTitleEmphasis: italic coral second line inside h2,
            // matching the live site's CTA emphasis treatment.
            var ctaBgValue = entry.getIn(['data', 'ctaBg']) || '';
            var ctaBgColor = heroBgMap[ctaBgValue] || heroBgFallback;

            var ctaEmphasis = get('ctaTitleEmphasis');
            var ctaH2Content = ctaEmphasis
              ? [
                  get('ctaTitle'),
                  h('span', { key: 'em', style: {
                    display:   'block',
                    fontStyle: 'italic',
                    color:     c.coral,
                  }}, ctaEmphasis),
                ]
              : get('ctaTitle');

            var ctaSection = h('section', {
              style: {
                background: ctaBgColor,
                padding:    '3.5rem 2rem',
                textAlign:  'center',
              }
            },
              h('div', { style: {
                maxWidth:     '640px',
                margin:       '0 auto',
                border:       '1.5px solid ' + c.sandDark,
                padding:      '2.5rem',
                background:   ctaBgColor,
              }},
                h('h2', { style: {
                  fontFamily:   fonts.display,
                  fontWeight:   '400',
                  fontSize:     'clamp(1.5rem, 3vw, 2.4rem)',
                  color:        c.driftwoodDk,
                  lineHeight:   '1.2',
                  marginBottom: '0.75rem',
                }}, ctaH2Content),
                h('p', { style: Object.assign({}, pStyle, { marginInline: 'auto', marginBottom: '1.5rem' }) },
                  get('ctaText')),
                h('span', { style: {
                  display:       'inline-block',
                  padding:       '0.75rem 2rem',
                  background:    c.tideDark,
                  color:         c.white,
                  fontFamily:    fonts.body,
                  fontSize:      '0.78rem',
                  fontWeight:    '500',
                  letterSpacing: '0.12em',
                  textTransform: 'uppercase',
                }}, get('ctaButtonText') || 'Get in Touch')
              )
            );

            // ── Assemble ──────────────────────────────────────────────────
            return h('div', { style: wrap },
              hero,
              skippedNotice,
              aboutStrip,
              ctaSection
            );
          }
        });

        window.CMS.registerPreviewTemplate('home', HomePreview);
        console.log('[preview-poc] registerPreviewTemplate("home") succeeded.');

      } catch (err) {
        console.error('[preview-poc] registerPreviewTemplate("home") failed:', err);
      }

    }());
  </script>
</body>
</html>
