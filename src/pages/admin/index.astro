      // ── Product Preview — Phase 1 ───────────────────────────────────────
      // Collection type: folder collection (first of this type in this project)
      // Registration: CMS.registerPreviewTemplate('products', ProductPreview)
      //
      // Phase 1 scope:
      //   Renders: title, category, description, price, status, quantity,
      //            featured, customOrderAvailable
      //   Gallery: first image via getAsset() with 6-step defensive fallback to placeholder
      //
      // Defensive rules applied:
      //   - All field reads guarded with || fallback
      //   - No method called on potentially-undefined value
      //   - Boolean fields read as primitives, not via method chains
      //   - status handled with explicit equality checks, never .toString()
      //   - price is a number widget — guarded with || 0, rendered via concatenation
      try {
        var ProductPreview = window.createClass({
          render: function () {
            var entry = this.props.entry;
            var h     = window.h;

            // ── Safe field reads ────────────────────────────────────────────
            var title               = entry.getIn(['data', 'title'])               || '';
            var category            = entry.getIn(['data', 'category'])            || '';
            var description         = entry.getIn(['data', 'description'])         || '';
            var price               = entry.getIn(['data', 'price'])               || 0;
            var status              = entry.getIn(['data', 'status'])              || 'available';
            var quantity            = entry.getIn(['data', 'quantity'])            || 0;
            var featured            = entry.getIn(['data', 'featured'])            || false;
            var customOrderAvail    = entry.getIn(['data', 'customOrderAvailable']) || false;

            // ── Status-derived values ───────────────────────────────────────
            var isAvailable  = status === 'available';
            var isPending    = status === 'pending';

            var badgeLabel = isAvailable ? 'Available'
                           : isPending   ? 'Pending Sale'
                           :               'Sold';

            var badgeBg    = isAvailable ? '#d4edda'
                           : isPending   ? '#fff3cd'
                           :               '#f8d7da';

            var badgeColor = isAvailable ? '#2d6a3f'
                           : isPending   ? '#856404'
                           :               '#721c24';

            // ── Shared local styles ─────────────────────────────────────────
            var metaLabelStyle = {
              fontFamily:    fonts.body,
              fontSize:      '0.65rem',
              fontWeight:    '500',
              letterSpacing: '0.15em',
              textTransform: 'uppercase',
              color:         c.tide,
              marginBottom:  '0.3rem',
            };

            var pStyle = {
              fontSize:     '0.95rem',
              color:        c.driftwoodDk,
              lineHeight:   '1.8',
              maxWidth:     '55ch',
              marginBottom: '0.5rem',
            };

            // ── Gallery — Phase 2: first image with full defensive fallback ──
            //
            // Six checks must all pass before an <img> is rendered.
            // Any falsy result at any step sets useImage = false and the
            // Phase 1 "Photos coming soon" placeholder is shown instead.
            // Nothing in this block can throw during render.
            //
            // Check 1: images list exists and has at least one entry
            var imagesList  = entry.getIn(['data', 'images']);
            var imagesOk    = imagesList && (
                                typeof imagesList.size  === 'number' ? imagesList.size  > 0 :
                                typeof imagesList.length === 'number' ? imagesList.length > 0 :
                                false
                              );

            // Check 2: first item exists
            var firstItem   = imagesOk ? entry.getIn(['data', 'images', 0]) : null;

            // Check 3: first item has an image value
            var rawImgVal   = firstItem ? entry.getIn(['data', 'images', 0, 'image']) : null;
            var imgPathOk   = rawImgVal && typeof rawImgVal === 'string' && rawImgVal.length > 0;

            // Check 4: getAsset prop exists and is a function
            var getAssetFn  = (typeof this.props.getAsset === 'function') ? this.props.getAsset : null;

            // Check 5: getAsset returns a truthy asset
            var asset       = (imgPathOk && getAssetFn) ? getAssetFn(rawImgVal) : null;
            var assetOk     = asset && asset.toString && asset.toString().length > 0;

            // Final gate
            var useImage    = !!(imagesOk && imgPathOk && getAssetFn && assetOk);

            // ── Gallery content: image or placeholder ─────────────────────
            var galleryContent = useImage
              ? h('img', {
                  src:   asset,
                  alt:   title || 'Product image',
                  style: {
                    width:      '100%',
                    height:     '100%',
                    objectFit:  'cover',
                    display:    'block',
                  },
                })
              : [
                  // SVG icon
                  h('svg', { key: 'svg',
                    width: '56', height: '56', viewBox: '0 0 24 24',
                    fill: 'none', stroke: c.driftwood, strokeWidth: '1',
                    style: { opacity: '0.5' }
                  },
                    h('rect',     { x: '3', y: '3', width: '18', height: '18', rx: '2' }),
                    h('circle',   { cx: '8.5', cy: '8.5', r: '1.5' }),
                    h('polyline', { points: '21 15 16 10 5 21' })
                  ),
                  // Label
                  h('p', { key: 'lbl', style: {
                    fontFamily:    fonts.body,
                    fontSize:      '0.8rem',
                    letterSpacing: '0.06em',
                    color:         c.driftwood,
                    opacity:       '0.7',
                  }}, 'Photos coming soon'),
                ];

            // ── Outer gallery wrapper (same dimensions and badge as Phase 1) ──
            var galleryPlaceholder = h('div', {
              style: {
                aspectRatio:    '1',
                background:     useImage
                                  ? 'transparent'
                                  : 'linear-gradient(135deg, ' + c.sand + ' 0%, ' + c.sandDark + ' 100%)',
                borderRadius:   '2px',
                overflow:       'hidden',
                display:        'flex',
                flexDirection:  'column',
                alignItems:     'center',
                justifyContent: 'center',
                gap:            '0.75rem',
                color:          c.driftwood,
                position:       'relative',
              }
            },
              // Featured badge — always overlaid regardless of image state
              featured && h('div', {
                style: {
                  position:      'absolute',
                  top:           '0.75rem',
                  left:          '0.75rem',
                  background:    c.coral,
                  color:         c.ink,
                  fontSize:      '0.6rem',
                  letterSpacing: '0.12em',
                  textTransform: 'uppercase',
                  padding:       '0.2rem 0.6rem',
                  fontWeight:    '500',
                  fontFamily:    fonts.body,
                  zIndex:        '1',
                }
              }, 'Featured'),
              galleryContent
            );

            // ── Product info column ─────────────────────────────────────────

            // Breadcrumb
            var breadcrumb = h('nav', {
              style: {
                padding:      '0.75rem 0',
                marginBottom: '1.5rem',
                fontSize:     '0.78rem',
                color:        c.driftwood,
                borderBottom: '1px solid ' + c.sandDark,
                display:      'flex',
                gap:          '0.4rem',
                alignItems:   'center',
              }
            },
              h('span', {}, 'Home'),
              h('span', { style: { color: c.sandDark } }, '›'),
              h('span', {}, 'Shop'),
              h('span', { style: { color: c.sandDark } }, '›'),
              h('span', { style: { color: c.tideDark } }, title || 'Product')
            );

            // Category + title + meta row
            var infoHeader = h('div', { style: { marginBottom: '1rem' } },
              h('p', { style: metaLabelStyle }, category),
              h('h1', { style: {
                fontFamily:   fonts.display,
                fontWeight:   '400',
                fontSize:     'clamp(1.8rem, 3vw, 2.8rem)',
                color:        c.driftwoodDk,
                lineHeight:   '1.15',
                marginBottom: '0.75rem',
                marginTop:    '0.2rem',
              }}, title || '(No title yet)'),
              // Price + status badge
              h('div', { style: {
                display:    'flex',
                alignItems: 'center',
                gap:        '1rem',
                flexWrap:   'wrap',
                marginBottom: '0.5rem',
              }},
                h('span', { style: {
                  fontFamily: fonts.display,
                  fontSize:   '1.75rem',
                  fontWeight: '400',
                  color:      c.coral,
                }}, price > 0 ? '$' + price : '—'),
                h('span', { style: {
                  display:       'inline-block',
                  padding:       '0.2rem 0.65rem',
                  fontSize:      '0.65rem',
                  fontWeight:    '500',
                  letterSpacing: '0.1em',
                  textTransform: 'uppercase',
                  borderRadius:  '20px',
                  background:    badgeBg,
                  color:         badgeColor,
                  fontFamily:    fonts.body,
                }}, badgeLabel),
                // Quantity — only shown when available and more than 1
                (isAvailable && quantity > 1) && h('span', { style: {
                  fontSize:   '0.75rem',
                  color:      c.driftwood,
                  fontFamily: fonts.body,
                }}, quantity + ' available')
              )
            );

            // Divider
            var divider = h('div', { style: {
              display:      'flex',
              alignItems:   'center',
              gap:          '1rem',
              marginBlock:  '1.25rem',
            }},
              h('div', { style: { flex: '1', height: '1px', background: c.sandDark } }),
              h('span', { style: {
                fontFamily: fonts.display,
                fontStyle:  'italic',
                color:      c.mist || c.driftwood,
                fontSize:   '1rem',
              }}, '✦'),
              h('div', { style: { flex: '1', height: '1px', background: c.sandDark } })
            );

            // Description
            var descSection = h('div', { style: { marginBottom: '1.25rem' } },
              h('p', { style: pStyle }, description || '(No description yet)')
            );

            // Custom order note
            var customNote = customOrderAvail
              ? h('div', { style: {
                  display:    'flex',
                  alignItems: 'flex-start',
                  gap:        '0.6rem',
                  padding:    '0.875rem 1rem',
                  background: c.sand,
                  borderLeft: '3px solid ' + c.tide,
                  marginBottom:'1rem',
                  fontSize:   '0.85rem',
                  color:      c.driftwood,
                  fontFamily: fonts.body,
                }},
                  h('svg', { width: '16', height: '16', viewBox: '0 0 24 24',
                             fill: 'none', stroke: c.tideDark, strokeWidth: '2',
                             style: { flexShrink: '0', marginTop: '2px' } },
                    h('path', { d: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' })
                  ),
                  h('span', {}, 'Custom orders available for this style.')
                )
              : null;

            // Action button
            var actionBtn = isAvailable
              ? h('div', { style: {
                  display:       'inline-block',
                  padding:       '1rem 2.5rem',
                  background:    c.tideDark,
                  color:         c.white,
                  fontFamily:    fonts.body,
                  fontSize:      '0.85rem',
                  fontWeight:    '500',
                  letterSpacing: '0.12em',
                  textTransform: 'uppercase',
                  marginBottom:  '0.75rem',
                }}, "I'm Interested")
              : h('div', { style: {
                  display:       'inline-block',
                  padding:       '1rem 2.5rem',
                  background:    'transparent',
                  color:         c.driftwood,
                  border:        '1.5px solid ' + c.driftwood,
                  fontFamily:    fonts.body,
                  fontSize:      '0.85rem',
                  fontWeight:    '500',
                  letterSpacing: '0.12em',
                  textTransform: 'uppercase',
                  opacity:       '0.7',
                  marginBottom:  '0.75rem',
                }}, isPending ? 'Pending Sale' : 'Sold');

            var actionNote = h('p', { style: {
              fontFamily: fonts.body,
              fontSize:   '0.78rem',
              color:      c.driftwood,
              maxWidth:   '48ch',
              lineHeight: '1.5',
              marginTop:  '0.25rem',
            }},
              isAvailable
                ? "Clicking \"I'm Interested\" opens a pre-filled contact form."
                : isPending
                  ? 'This piece has a pending sale.'
                  : 'This piece has sold.'
            );

            // Details table
            var detailsTable = h('div', { style: {
              marginTop:   '2rem',
              paddingTop:  '1.5rem',
              borderTop:   '1px solid ' + c.sandDark,
            }},
              h('p', { style: {
                fontFamily:    fonts.body,
                fontSize:      '0.7rem',
                fontWeight:    '500',
                letterSpacing: '0.15em',
                textTransform: 'uppercase',
                color:         c.tide,
                marginBottom:  '1rem',
              }}, 'Details'),
              h('dl', { style: { display: 'flex', flexDirection: 'column', gap: '0.5rem' } },
                [
                  ['Category',     category     || '—'],
                  ['Availability', status       || '—'],
                  ['Quantity',     quantity > 0 ? String(quantity) : '—'],
                  ['Custom Orders', customOrderAvail ? 'Yes' : 'No'],
                ].map(function (pair, i) {
                  return h('div', { key: i, style: { display: 'flex', gap: '1rem' } },
                    h('dt', { style: {
                      fontFamily: fonts.body,
                      fontSize:   '0.78rem',
                      fontWeight: '500',
                      color:      c.driftwood,
                      minWidth:   '130px',
                    }}, pair[0]),
                    h('dd', { style: {
                      fontFamily: fonts.body,
                      fontSize:   '0.85rem',
                      color:      c.ink,
                      textTransform: pair[0] === 'Availability' ? 'capitalize' : 'none',
                    }}, pair[1])
                  );
                })
              )
            );

            // ── Assemble product info column ────────────────────────────────
            var infoCol = h('div', { style: { flex: '1', minWidth: '0' } },
              breadcrumb,
              infoHeader,
              divider,
              descSection,
              customNote,
              h('div', { style: { marginTop: '1.75rem', display: 'flex', flexDirection: 'column', gap: '0.5rem' } },
                actionBtn,
                actionNote
              ),
              detailsTable
            );

            // ── Two-column layout ───────────────────────────────────────────
            var layout = h('section', { style: { padding: '2.5rem 2rem' } },
              h('div', { style: {
                maxWidth:   '1100px',
                margin:     '0 auto',
                display:    'flex',
                gap:        '3.5rem',
                alignItems: 'flex-start',
                flexWrap:   'wrap',
              }},
                // Left — gallery placeholder
                h('div', { style: { flex: '1', minWidth: '280px' } },
                  galleryPlaceholder
                ),
                // Right — info
                infoCol
              )
            );

            return h('div', { style: {
              fontFamily: fonts.body,
              background: c.shell,
              color:      c.ink,
              minHeight:  '100vh',
              lineHeight: '1.7',
              fontSize:   '16px',
            }}, layout);
          }
        });

        window.CMS.registerPreviewTemplate('products', ProductPreview);
        console.log('[preview-poc] registerPreviewTemplate("products") succeeded.');

      } catch (err) {
        console.error('[preview-poc] registerPreviewTemplate("products") failed:', err);
      }

    }());
  </script>
</body>
</html>
